/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tuition_plans {
  id               Int                   @id @default(autoincrement())
  course_id        Int
  name             String                @db.VarChar(150)
  price            Decimal               @db.Decimal(12, 2)
  original_price   Decimal?              @db.Decimal(12, 2)
  duration         String?               @db.VarChar(100)
  description      String?               @db.Text
  benefits         String?               @db.Text
  is_discount      Boolean?              @default(false)
  discount_percent Int?                  @default(0)
  status           tuition_plans_status? @default(ACTIVE)
  created_at       DateTime?             @default(now()) @db.Timestamp(0)
  updated_at       DateTime?             @default(now()) @db.Timestamp(0)
  courses          courses               @relation(fields: [course_id], references: [id], map: "fk_tuition_course")

  @@index([course_id], map: "fk_tuition_course")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id                  Int                   @id @default(autoincrement())
  role_id             Int
  full_name           String                @db.VarChar(100)
  email               String                @unique(map: "email") @db.VarChar(150)
  phone               String?               @db.VarChar(20)
  password_hash       String                @db.VarChar(255)
  avatar              String?               @db.VarChar(500)
  date_of_birth       DateTime?             @db.Date
  gender              users_gender?
  address             String?               @db.VarChar(255)
  status              users_status?         @default(ACTIVE)
  created_at          DateTime?             @default(now()) @db.Timestamp(0)
  updated_at          DateTime?             @default(now()) @db.Timestamp(0)
  refresh_token       String?               @db.VarChar(500)
  enrollments         enrollments[]
  news                news[]
  password_resets     password_resets[]
  placement_tests     placement_tests[]
  registrations       registrations[]
  teachers            teachers?
  trial_registrations trial_registrations[]
  roles               roles                 @relation(fields: [role_id], references: [id], map: "fk_users_roles")

  @@index([role_id], map: "fk_users_roles")
}

model password_resets {
  id         Int       @id @default(autoincrement())
  user_id    Int
  otp        String    @db.VarChar(10)
  expired_at DateTime  @db.DateTime(0)
  is_used    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.DateTime(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_user")

  @@index([user_id], map: "fk_password_reset_user")
}

enum payments_payment_method {
  CASH
  BANK_TRANSFER
  ONLINE
}

enum attendance_status {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum enrollments_status {
  PENDING
  ACTIVE
  COMPLETED
  DROPPED
  CANCELLED
}

enum news_categories_status {
  ACTIVE
  INACTIVE
}

enum course_categories_status {
  ACTIVE
  INACTIVE
}

enum payments_status {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum opening_schedules_study_method {
  OFFLINE
  ONLINE
  BOTH
}

enum assignments_status {
  DRAFT
  PUBLISHED
  CLOSED
