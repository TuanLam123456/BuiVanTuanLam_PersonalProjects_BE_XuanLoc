  OTHER
}

enum courses_study_method {
  OFFLINE
  ONLINE
  BOTH
}

enum tuition_plans_status {
  ACTIVE
  INACTIVE
}

enum users_status {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum classes_status {
  PLANNING
  OPEN
  RUNNING
  FINISHED
  CANCELLED
}

enum courses_status {
  ACTIVE
  INACTIVE
  DRAFT
