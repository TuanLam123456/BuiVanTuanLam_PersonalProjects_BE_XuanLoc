/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model registrations {
  id         Int                   @id @default(autoincrement())
  user_id    Int?
  course_id  Int?
  full_name  String                @db.VarChar(100)
  phone      String                @db.VarChar(20)
  email      String?               @db.VarChar(150)
  message    String?               @db.Text
  source     registrations_source? @default(CONTACT_PAGE)
  status     registrations_status? @default(NEW)
  note       String?               @db.Text
  created_at DateTime?             @default(now()) @db.Timestamp(0)
  updated_at DateTime?             @default(now()) @db.Timestamp(0)
  courses    courses?              @relation(fields: [course_id], references: [id], map: "fk_registration_course")
  users      users?                @relation(fields: [user_id], references: [id], map: "fk_registration_user")

  @@index([course_id], map: "fk_registration_course")
  @@index([user_id], map: "fk_registration_user")
