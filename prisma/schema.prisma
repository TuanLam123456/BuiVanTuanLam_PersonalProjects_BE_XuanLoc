/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model roles {
  id          Int       @id @default(autoincrement())
  name        String    @unique(map: "name") @db.VarChar(50)
  description String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model teacher_courses {
  id          Int       @id @default(autoincrement())
  teacher_id  Int
  course_id   Int
  role        String?   @db.VarChar(100)
  assigned_at DateTime? @default(now()) @db.Timestamp(0)
  courses     courses   @relation(fields: [course_id], references: [id], onDelete: Cascade, map: "fk_teacher_courses_course")
  teachers    teachers  @relation(fields: [teacher_id], references: [id], onDelete: Cascade, map: "fk_teacher_courses_teacher")

  @@unique([teacher_id, course_id], map: "unique_teacher_course")
  @@index([course_id], map: "fk_teacher_courses_course")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model teachers {
  id                Int                 @id @default(autoincrement())
  user_id           Int                 @unique(map: "user_id")
  specialization    String?             @db.VarChar(150)
  experience        String?             @db.VarChar(100)
  education         String?             @db.VarChar(255)
  introduction      String?             @db.Text
  avatar            String?             @db.VarChar(500)
  phone             String?             @db.VarChar(20)
  status            teachers_status?    @default(ACTIVE)
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  updated_at        DateTime?           @default(now()) @db.Timestamp(0)
  assignments       assignments[]
  classes           classes[]
  grades            grades[]
  opening_schedules opening_schedules[]
  teacher_courses   teacher_courses[]
  users             users               @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_teachers_users")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model trial_registrations {
  id             Int                         @id @default(autoincrement())
  user_id        Int?
  course_id      Int?
  full_name      String                      @db.VarChar(100)
  phone          String                      @db.VarChar(20)
  email          String?                     @db.VarChar(150)
  age            Int?
  current_level  String?                     @db.VarChar(100)
  preferred_time String?                     @db.VarChar(255)
  note           String?                     @db.Text
  trial_date     DateTime?                   @db.Date
  status         trial_registrations_status? @default(NEW)
  created_at     DateTime?                   @default(now()) @db.Timestamp(0)
  updated_at     DateTime?                   @default(now()) @db.Timestamp(0)
  courses        courses?                    @relation(fields: [course_id], references: [id], map: "fk_trial_course")
  users          users?                      @relation(fields: [user_id], references: [id], map: "fk_trial_user")

  @@index([course_id], map: "fk_trial_course")
